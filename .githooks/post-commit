#!/usr/bin/env bash
# .githooks/post-commit  (commit this file)
#
# Refreshes graphify-out/graph.json and the human-facing Obsidian vault on every
# commit. Runs in bash (Git for Windows ships bash), so it's the same file on
# every OS — only the graphify binary path differs:
#   POSIX (Mac/Linux/WSL):     .venv/bin/graphify
#   Native Windows (Git Bash): .venv/Scripts/graphify.exe
# Set GRAPHIFY_PY to override if your venv lives elsewhere, e.g.
#   export GRAPHIFY_PY=".venv/Scripts/graphify.exe"
GRAPHIFY="${GRAPHIFY_PY:-.venv/bin/graphify}"
"$GRAPHIFY" update . >/dev/null 2>&1 || "$GRAPHIFY" extract . >/dev/null 2>&1
"$GRAPHIFY" export obsidian --dir docs/graph-vault >/dev/null 2>&1
echo "graphify: graph + vault refreshed"
